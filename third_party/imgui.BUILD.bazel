load("@rules_cc//cc:cc_library.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

licenses(["notice"])

cc_library(
    name = "imgui_core",
    srcs = [
        "imgui.cpp",
        "imgui_demo.cpp",
        "imgui_draw.cpp",
        "imgui_tables.cpp",
        "imgui_widgets.cpp",
    ],
    hdrs = [
        "imconfig.h",
        "imgui.h",
        "imgui_internal.h",
        "imstb_rectpack.h",
        "imstb_textedit.h",
        "imstb_truetype.h",
    ],
    includes = ["."],
)

cc_library(
    name = "imgui_sdl3_backend",
    srcs = ["backends/imgui_impl_sdl3.cpp"],
    hdrs = ["backends/imgui_impl_sdl3.h"],
    includes = [
        ".",
        "backends",
    ],
    deps = [
        ":imgui_core",
        "@sdl3",
    ],
)

cc_library(
    name = "imgui_vulkan_backend",
    srcs = ["backends/imgui_impl_vulkan.cpp"],
    hdrs = ["backends/imgui_impl_vulkan.h"],
    includes = [
        ".",
        "backends",
    ],
    deps = [
        ":imgui_core",
        "@vk_sdk//:vulkan",
    ],
)

cc_library(
    name = "imgui",
    deps = [
        ":imgui_core",
        ":imgui_sdl3_backend",
        ":imgui_vulkan_backend",
    ],
)
